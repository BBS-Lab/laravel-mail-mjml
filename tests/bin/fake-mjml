#!/usr/bin/env bash
set -euo pipefail

input=""
output=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -o)
            output="$2"
            shift 2
            ;;
        --config.*)
            shift
            ;;
        *)
            input="$1"
            shift
            ;;
    esac
done

if [[ -z "${input}" || -z "${output}" ]]; then
    echo "fake-mjml: input and -o output are required" >&2
    exit 1
fi

escaped=$(sed 's/\\/\\\\/g; s/"/\\"/g' "${input}" | tr '\n' ' ')

cat > "${output}" <<EOF
<!DOCTYPE html>
<html>
  <body data-mjml-compiled="true">${escaped}</body>
</html>
EOF
