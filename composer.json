{
    "name": "bbs-lab/laravel-mail-mjml",
    "description": "Laravel package for building responsive emails with MJML and Mailables.",
    "keywords": [
        "BBS",
        "laravel",
        "laravel-mail-mjml",
        "mjml",
        "email",
        "mail"
    ],
    "homepage": "https://github.com/BBS-Lab/laravel-mail-mjml",
    "license": "MIT",
    "authors": [
        {
            "name": "BBS",
            "email": "paris@big-boss-studio.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "illuminate/mail": "^11.0||^12.0||^13.0",
        "illuminate/support": "^11.0||^12.0||^13.0",
        "illuminate/view": "^11.0||^12.0||^13.0",
        "soundasleep/html2text": "^2.1",
        "spatie/laravel-package-tools": "^1.16",
        "symfony/process": "^7.0||^8.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^9.16||^10.9||^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-mutate": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "BBSLab\\LaravelMjml\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BBSLab\\LaravelMjml\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest --testsuite=Package",
        "test-mjml": [
            "@clean",
            "vendor/bin/pest --testsuite=MjmlE2e"
        ],
        "test-coverage": [
            "@clean",
            "XDEBUG_MODE=coverage vendor/bin/pest --testsuite=Package --coverage --min=100"
        ],
        "test-mutation": [
            "@clean",
            "@php scripts/ensure-pest-mutate-temp.php",
            "XDEBUG_MODE=coverage vendor/bin/pest --testsuite=Package --mutate --path=src --covered-only --min=65"
        ],
        "format": "vendor/bin/pint",
        "clean": "@php scripts/clean-test-artifacts.php"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BBSLab\\LaravelMjml\\LaravelMjmlServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
